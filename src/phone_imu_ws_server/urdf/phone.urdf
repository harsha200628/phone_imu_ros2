<?xml version="1.0"?>
<robot name="phone">
  <link name="base_link"/>
  
  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="phone_imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="phone_imu_link">
    <visual>
      <geometry>
        <box size="0.32 0.16 0.02"/>
      </geometry>
      <material name="vibrant_red">
        <color rgba="1.0 0.1 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.32 0.16 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
</robot>
